{
  "manifest_version": 3,
  "name": "PotatoPlus",
  "version": "0.4.0",
  "description": "Potato Overflow! NJU土豆改善工程",
  "icons": {
    "96": "img/logo96.png",
    "128": "img/logo128.png",
    "512": "img/logo512.png",
    "1024": "img/logo1024.png"
  },
  "author": "Limos",
  "content_scripts": [
    {
      "matches": ["*://*.nju.edu.cn/jiaowu*", "*://xk.nju.edu.cn/*"],
      "css": ["css/material-components-web.min.css", "css/pjw.css", "css/pjw-classlist.css", "css/pjw-filter.css", "css/pjw-console.css"],
      "js": ["js/inject.js"],
      "run_at": "document_start",
      "all_frames": true
    },
    {
      "matches": ["*://authserver.nju.edu.cn/*"],
      "js": ["js/inject.js"],
      "run_at": "document_start",
      "all_frames": true
    },
    {
      "matches": ["*://ehallapp.nju.edu.cn/jwapp/sys/wspjyyapp/*"],
      "js": ["js/inject.js"],
      "run_at": "document_start",
      "all_frames": true
    },
    {
      "matches": ["*://ehallapp.nju.edu.cn/jwapp/sys/cjcx/*"],
      "js": ["js/inject.js"],
      "run_at": "document_start",
      "all_frames": true
    },
    {
      "matches": ["*://ehall.nju.edu.cn/ywtb-portal/*"],
      "js": ["js/inject.js", "js/ehall/schedule-bridge.js"],
      "run_at": "document_start",
      "all_frames": true
    }
  ],
  "web_accessible_resources": [{
    "resources": ["js/*","css/*","fonts/*"],
    "matches": ["*://*.nju.edu.cn/*", "*://ehallapp.nju.edu.cn/*"]
  }],
  "permissions": [
    "nativeMessaging"
  ],
  "background": {
    "service_worker": "js/background.js"
  },
  "host_permissions": [
    "*://*.nju.edu.cn/jiaowu*",
    "*://xk.nju.edu.cn/*",
    "*://authserver.nju.edu.cn/*",
    "*://ehallapp.nju.edu.cn/*",
    "*://ehall.nju.edu.cn/*",
    "*://potatoplus.zcec.top/*"
  ],
  "browser_specific_settings": {
    "gecko": {
      "update_url": "https://github.com/GreenTeodoro839/PotatoPlus/releases/latest/download/updates.json"
    }
  }
}
